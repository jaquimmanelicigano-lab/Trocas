# ============================================
# Variáveis de Ambiente - Projeto Trocas
# ============================================
# Não partilhe este ficheiro!
# Adicione .env ao .gitignore

# ==================== BASE DE DADOS ====================
# Host do servidor MySQL
DB_HOST=localhost
# Nome de utilizador MySQL
DB_USER=root
# Password do utilizador MySQL
DB_PASSWORD=teste123
# Nome da base de dados
DB_NAME=trocas_db

# ==================== SERVIDOR ====================
# Porta do servidor (padrão: 3000)
PORT=3000
# Chave secreta para sessões (mudar em produção!)
SESSION_SECRET=trocas_secret_key_2024_change_in_production

# ==================== UPLOAD DE FICHEIROS ====================
# Pasta onde serão guardadas as imagens
UPLOAD_PATH=./src/public/images/uploads
# Tamanho máximo dos ficheiros (em bytes) - 5MB
MAX_FILE_SIZE=5242880

# ==================== EMAIL (SMTP) ====================
# Servidor SMTP (gmail, outlook, etc)
MAIL_SERVER=smtp.gmail.com
# Porta SMTP (587 para TLS, 465 para SSL)
MAIL_PORT=587
# Usar TLS (True/False)
MAIL_USE_TLS=True
# Email do remetente
MAIL_USERNAME=trocassuporte@gmail.com
# Password ou App Password do email
MAIL_PASSWORD=hrwo wkdc jtfb lwse
